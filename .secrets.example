# Copy this file to `.secrets` and fill in real values.
# `.secrets` is git-ignored; this `.example` is safe to commit.
#
# Upload to the deployed Worker (stored encrypted on Cloudflare, persists
# across deploys):
#     uv run pywrangler secret bulk .secrets
#
# For an occasional local run (`pywrangler dev`), point it at this file:
#     uv run pywrangler dev --env-file .secrets
#
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Only needed for temporary STS credentials:
# AWS_SESSION_TOKEN=
